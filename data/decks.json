    {
      "name": "Lesson 3\u20134 Quiz",
      "mode": "qa",
      "items": [
        {
          "q": "Lesson 3 enabling objectives (list)",
          "a": "Define categories of Naval Messages; Identify Naval Message Procedures; Identify Special Categories and Handling."
        },
        {
          "q": "What are the three Naval message categories covered in Lesson 3?",
          "a": "GENSER; DSSCS; CRITIC."
        },
        {
          "q": "GENSER stands for",
          "a": "General Service."
        },
        {
          "q": "DSSCS stands for",
          "a": "Defense Special Security Communications System(s)."
        },
        {
          "q": "What is a CRITIC message?",
          "a": "A message used to report critical information with essential facts to senior government decision makers (the President)."
        },
        {
          "q": "Define GENSER (Lesson 3 definition)",
          "a": "Most widely used DoD message format; usually UNCLASSIFIED but can be classified up to TOP SECRET."
        },
        {
          "q": "GENSER typical classification",
          "a": "Most are UNCLASSIFIED (can be up to TOP SECRET)."
        },
        {
          "q": "Define DSSCS",
          "a": "Worldwide, special purpose communications system used to process record message traffic."
        },
        {
          "q": "DSSCS can contain what types of information?",
          "a": "Sensitive Information (SI) and can contain SCI."
        },
        {
          "q": "DSSCS shares transmission paths with what?",
          "a": "AUTODIN."
        },
        {
          "q": "DSSCS can communicate with what units?",
          "a": "Shore, Sea, and Air units."
        },
        {
          "q": "CRITIC message purpose",
          "a": "Report critical information with essential facts about an event/situation to senior decision makers (the President)."
        },
        {
          "q": "CRITIC uses what format?",
          "a": "Modified SI message format."
        },
        {
          "q": "CRITIC messages are typically what length/type?",
          "a": "Short, specifically formatted messages."
        },
        {
          "q": "CRITIC messages are sent at what priority?",
          "a": "Highest priority."
        },
        {
          "q": "CRITIC messages transmitted via what?",
          "a": "Most rapid communications paths available."
        },
        {
          "q": "Define \u201cmessage user\u201d (Lesson 3)",
          "a": "Any individual authorized to draft, release, and/or process electronically transmitted messages."
        },
        {
          "q": "Naval message procedure roles (Lesson 3 list)",
          "a": "Originator; Drafter; Releaser."
        },
        {
          "q": "Can message responsibilities overlap?",
          "a": "Yes; one person may serve dual capacity (e.g., communications officer drafts and releases)."
        },
        {
          "q": "Define Originator (Naval messaging)",
          "a": "The authority (command/activity) in whose name the message is sent."
        },
        {
          "q": "Who is presumed to be the originator?",
          "a": "The Commanding Officer of the command/activity."
        },
        {
          "q": "Originator and releaser relationship (most often)",
          "a": "Most often the originator and the releaser are the same."
        },
        {
          "q": "Example where originator=drafter=releaser",
          "a": "If the CO drafts a message, they are drafter and releasing authority (and originator authority)."
        },
        {
          "q": "Define Drafter",
          "a": "The person who actually composes the message."
        },
        {
          "q": "Drafter responsibility: addressing",
          "a": "Proper addressing and correct use of Plain Language Address (PLA) designators."
        },
        {
          "q": "Drafter responsibility: writing style",
          "a": "Clear, concise composition."
        },
        {
          "q": "Drafter responsibility: precedence",
          "a": "Select the precedence."
        },
        {
          "q": "Drafter responsibility: format",
          "a": "Ensure the proper format."
        },
        {
          "q": "Drafter responsibility: classification",
          "a": "Assign the proper classification."
        },
        {
          "q": "Drafter responsibility: downgrading/declass",
          "a": "Apply downgrading and declassification instructions to classified messages (except RD/FRD)."
        },
        {
          "q": "Define Releaser",
          "a": "Properly designated individual authorized to release messages for transmission in the name of the command/activity."
        },
        {
          "q": "Releaser checks what?",
          "a": "Ensures the drafter complied with applicable instructions."
        },
        {
          "q": "What does the releaser\u2019s signature affirm?",
          "a": "Compliance with message drafting instructions and validates contents."
        },
        {
          "q": "What does the releaser\u2019s signature authorize?",
          "a": "Authorizes the message for transmission."
        },
        {
          "q": "After release, where does message go?",
          "a": "Delivered to telecommunications/message center for transmission."
        },
        {
          "q": "Releaser authorization rule",
          "a": "List of authorized releasers must be adhered to; do not assume someone can sign without written authorization."
        },
        {
          "q": "Outgoing message process (high-level flow)",
          "a": "Drafter drafts \u2192 chain of command approval/changes \u2192 drafter updates \u2192 final approval \u2192 delivered to message center \u2192 operator releases \u2192 message released and logged."
        },
        {
          "q": "Incoming message process (high-level flow)",
          "a": "Message received \u2192 queued/sorted using profilers \u2192 routed by profiler to specific people \u2192 logged and filed onboard."
        },
        {
          "q": "Special handling markings (Lesson 3 list)",
          "a": "Caveat; RD; FRD; LIMDIS; FOUO; EFTO; SPECAT; PERSONAL FOR; NATO RESTRICTED; ALLIED RESTRICTED."
        },
        {
          "q": "Define \u201ccaveat\u201d (special-handling)",
          "a": "Warning by authoritative orders directing protection of an element (usually special message traffic)."
        },
        {
          "q": "Caveat examples in notes",
          "a": "SCI; NATO."
        },
        {
          "q": "RD stands for",
          "a": "Restricted Data."
        },
        {
          "q": "FRD stands for",
          "a": "Formerly Restricted Data."
        },
        {
          "q": "Define Restricted Data (RD)",
          "a": "Data about design, manufacture, or use of nuclear weapons; includes special nuclear material used in energy production."
        },
        {
          "q": "Define Formerly Restricted Data (FRD)",
          "a": "Defense information removed from RD category but still safeguarded as classified defense info."
        },
        {
          "q": "FRD release limitation",
          "a": "Cannot be released to foreign nationals except under specific international agreement."
        },
        {
          "q": "FOUO stands for",
          "a": "For Official Use Only."
        },
        {
          "q": "Define FOUO",
          "a": "Official information not requiring classification but must be protected from public release."
        },
        {
          "q": "How mark FOUO in unclassified messages?",
          "a": "Place \u201cFOUO\u201d after \u201cUNCLAS.\u201d"
        },
        {
          "q": "EFTO stands for",
          "a": "Encrypted For Transmission Only."
        },
        {
          "q": "Define EFTO",
          "a": "Protect certain unclassified messages with potential value if analyzed during electrical transmission."
        },
        {
          "q": "Is EFTO required on unclassified messages?",
          "a": "No (not required)."
        },
        {
          "q": "SPECAT stands for",
          "a": "SPEcial CATegory."
        },
        {
          "q": "Define SPECAT",
          "a": "Classified messages tied to special project/subject requiring extra handling beyond normal classification procedures."
        },
        {
          "q": "Four SPECAT categories",
          "a": "Limited Distribution (LIMDIS); Personal For; NATO Restricted; Allied Restricted."
        },
        {
          "q": "LIMDIS stands for",
          "a": "LIMitied DIStribution."
        },
        {
          "q": "Define PERSONAL FOR (as marking)",
          "a": "A special handling/passing instruction indicating personal delivery/handling (as listed)."
        },
        {
          "q": "Define NATO RESTRICTED (as marking)",
          "a": "Special handling marking for NATO restricted material (as listed)."
        },
        {
          "q": "Define ALLIED RESTRICTED (as marking)",
          "a": "Special handling marking for allied restricted material (as listed)."
        },
        {
          "q": "COMMSHIFT stands for",
          "a": "Communications Guard Shift message."
        },
        {
          "q": "When is a COMMSHIFT message required?",
          "a": "When a command shifts guard from one broadcast/servicing comm center to another."
        },
        {
          "q": "Preferred COMMSHIFT effective time",
          "a": "0001Z of the new radio day (when possible)."
        },
        {
          "q": "COMMSHIFT sent to whom?",
          "a": "NCTAMS of the comm areas from which old and new broadcasts originate."
        },
        {
          "q": "Why are COMMSHIFT messages necessary?",
          "a": "Operational considerations or changes in deployment schedule."
        },
        {
          "q": "COMMSPOT stands for",
          "a": "Communications Spot Report."
        },
        {
          "q": "Purpose of COMMSPOT",
          "a": "Advise of situations causing significant disruption of tactical communications."
        },
        {
          "q": "Who submits COMMSPOT?",
          "a": "All ships when communications difficulties are encountered."
        },
        {
          "q": "When must COMMSPOT be submitted?",
          "a": "As soon as difficulties are experienced to minimize further deterioration."
        },
        {
          "q": "PLA stands for",
          "a": "Plain Language Address."
        },
        {
          "q": "Define PLA",
          "a": "Station address written so it\u2019s easily understood when read."
        },
        {
          "q": "Examples of PLA",
          "a": "USS YORKTOWN; COMDESRON TEN; COMSECONDFLT (as shown)."
        },
        {
          "q": "AIG stands for",
          "a": "Address Indicator Group."
        },
        {
          "q": "Define AIG",
          "a": "Address designator representing a collection of 16 or more frequently occurring PLAs."
        },
        {
          "q": "CAD stands for",
          "a": "Collective Address Designator."
        },
        {
          "q": "Define CAD",
          "a": "Address designator representing 4 or more PLAs sharing a common operational and/or administrative chain of command."
        },
        {
          "q": "CAD examples (from notes)",
          "a": "ENTSTRKGRU; TRUSTKGRU."
        },
        {
          "q": "Lesson 4 enabling objectives (list)",
          "a": "Identify the GENSER message; Describe format lines of a GENSER message; Prepare a GENSER message."
        },
        {
          "q": "Define GENSER (Lesson 4)",
          "a": "Most widely used DoD message format; usually UNCLASSIFIED but can be up to TOP SECRET."
        },
        {
          "q": "Why are GENSER messages broken down by format lines?",
          "a": "Format lines help drafter/originator/software handle and route messages based on the info in the lines."
        },
        {
          "q": "3 components of a message",
          "a": "Header; Body; Footer."
        },
        {
          "q": "GENSER Format Line 1 name",
          "a": "Transmission Identification."
        },
        {
          "q": "Format Line 1 typically inserted by whom?",
          "a": "Message handling system (usually)."
        },
        {
          "q": "What does VZCZC indicate?",
          "a": "Start of a message."
        },
        {
          "q": "Format Line 1 station/channel designator purpose",
          "a": "Identifies station/channel (e.g., YKN=USS YORKTOWN)."
        },
        {
          "q": "Format Line 1 sequential number meaning",
          "a": "3-digit sequential number of transmissions."
        },
        {
          "q": "GENSER Format Line 2 name",
          "a": "Message Header Information (Message Header)."
        },
        {
          "q": "Format Line 2 first character meaning",
          "a": "Precedence indicator (must match throughout message)."
        },
        {
          "q": "Precedence codes (as listed)",
          "a": "R=Routine; P=Priority; O=Immediate; Z=Flash."
        },
        {
          "q": "Format Line 2 characters 2\u20133 meaning",
          "a": "Language Media Format (LMF) indicator."
        },
        {
          "q": "Format Line 2 4th character meaning",
          "a": "Message classification (U/C/S/T)."
        },
        {
          "q": "Classification codes in header",
          "a": "U=Unclassified; C=Confidential; S=Secret; T=Top Secret."
        },
        {
          "q": "Content Indicator Code (CIC) definition",
          "a": "Indicates what type of information is contained in the message."
        },
        {
          "q": "ZYUW indicates what?",
          "a": "Narrative message (per example)."
        },
        {
          "q": "Format Line 2 character 9 meaning",
          "a": "Separator space (required)."
        },
        {
          "q": "OSRI stands for",
          "a": "Originating Station\u2019s Routing Indicator."
        },
        {
          "q": "OSRI purpose",
          "a": "Identifies who drafted/transmitted; unique per command."
        },
        {
          "q": "SSN stands for",
          "a": "Station Serial Number."
        },
        {
          "q": "SSN format in header",
          "a": "4-digit number from 0001 through 9998 (runs consecutively)."
        },
        {
          "q": "Julian date in Format Line 2",
          "a": "Three digits: 001 on 1 Jan through 365 (or 366 leap year)."
        },
        {
          "q": "Time field in Format Line 2",
          "a": "4-digit time received by originator comm center; expressed in GMT/Zulu."
        },
        {
          "q": "Classification redundancy in header",
          "a": "Single hyphen then classification character repeated 4 times (e.g., UUUU, CCCC, SSSS, TTTT)."
        },
        {
          "q": "Routing indicators begin with what?",
          "a": "\u201c--\u201d start of routing information signal."
        },
        {
          "q": "End of routing signal character",
          "a": "\u201c.\u201d (period) used when last routing indicator inserted."
        },
        {
          "q": "GENSER Format Line 4 name",
          "a": "Security Warning."
        },
        {
          "q": "Format Line 4 structure",
          "a": "3-letter operating signal + classification character repeated five times."
        },
        {
          "q": "OPSIG definition (as described)",
          "a": "3-letter group code used to convey orders/instructions/requests/reports to speed communications."
        },
        {
          "q": "OPSIG used for unclassified traffic",
          "a": "ZNR UUUUU."
        },
        {
          "q": "OPSIG used for Confidential or higher example",
          "a": "ZNY CCCCC."
        },
        {
          "q": "GENSER Format Line 5 name",
          "a": "Date-Time Group (DTG)."
        },
        {
          "q": "DTG line starts with what?",
          "a": "Message precedence + space."
        },
        {
          "q": "DTG components (example meaning)",
          "a": "Day (DD), Time (HHMM), Z (Zulu/GMT), Month (MMM), Year (YY)."
        },
        {
          "q": "GENSER Format Line 6 name",
          "a": "Originator."
        },
        {
          "q": "What does \u201cFM\u201d indicate?",
          "a": "Message originator line (FROM)."
        },
        {
          "q": "Format Line 6 contains what?",
          "a": "Originator PLA (where message is coming from)."
        },
        {
          "q": "GENSER Format Line 7 name",
          "a": "Action Addressee."
        },
        {
          "q": "What does \u201cTO\u201d indicate?",
          "a": "Action addressee (who must take action)."
        },
        {
          "q": "Format Line 7 contains what?",
          "a": "Action addressee PLA (where message is going to for action)."
        },
        {
          "q": "GENSER Format Line 8 name",
          "a": "Information Addressee."
        },
        {
          "q": "What does \u201cINFO\u201d indicate?",
          "a": "Addressee informed only; no action required."
        },
        {
          "q": "Format Line 8 contains what?",
          "a": "INFO addressee PLA(s)."
        },
        {
          "q": "GENSER Format Line 11 name",
          "a": "Break."
        },
        {
          "q": "Format Line 11 prosign",
          "a": "BT."
        },
        {
          "q": "BT meaning",
          "a": "Break between header and text/body."
        },
        {
          "q": "GENSER Format Line 12 name",
          "a": "Text."
        },
        {
          "q": "First word of Format Line 12 indicates what?",
          "a": "Security designation (overall classification of the message text)."
        },
        {
          "q": "If message contains no classified data, use what?",
          "a": "UNCLAS."
        },
        {
          "q": "How to write classification in text when classified",
          "a": "Spell out completely with a space between each character (e.g., S E C R E T)."
        },
        {
          "q": "SSIC stands for",
          "a": "Standard Subject Identification Code."
        },
        {
          "q": "SSIC purpose",
          "a": "Aids automated internal routing and filing; required on Navy/Marine Corps letters/messages/directives/forms/reports."
        },
        {
          "q": "SSIC length",
          "a": "4 or 5 digits."
        },
        {
          "q": "SSIC manual reference (as listed)",
          "a": "SECNAV M-5210.2."
        },
        {
          "q": "Passing instructions are placed where?",
          "a": "After SSIC in Format Line 12 when needed (FOR/FROM/PASS TO etc.)."
        },
        {
          "q": "MSGID in Format Line 12 indicates what?",
          "a": "Message identification for GENSER messages."
        },
        {
          "q": "Subject line format",
          "a": "Starts with \u201cSUBJ/\u201d and ends with \u201c//\u201d."
        },
        {
          "q": "When subject is unclassified but message is classified, mark subject how?",
          "a": "End subject with (U)."
        },
        {
          "q": "If subject contains classified info, mark with what?",
          "a": "Appropriate classification symbol (C), (S), or (TS)."
        },
        {
          "q": "REF line purpose",
          "a": "Identify pertinent references (message/document/meeting/telcon/etc.)."
        },
        {
          "q": "Reference type codes (as listed)",
          "a": "CON (conference/meeting); DOC (document/publication); LTR (letter/email/etc.); MSG (record message); TEL (telephone conversation)."
        },
        {
          "q": "AMPN meaning",
          "a": "Amplifying information line for references when needed."
        },
        {
          "q": "When use AMPN (as stated)",
          "a": "When only one reference and it requires additional discussion OR it is one of TEL/CON/DOC/MSG/LTR."
        },
        {
          "q": "RMKS purpose",
          "a": "Explain the purpose of the message."
        },
        {
          "q": "Downgrading/declassification rule (as stated)",
          "a": "Naval messages automatically downgraded after 10 years unless exempt; apply downgrading and declassification marks to all classified messages."
        },
        {
          "q": "DECL/X1 category",
          "a": "Intel source/method/activity or cryptologic system/activity."
        },
        {
          "q": "DECL/X2 category",
          "a": "Assists development/use of weapons of mass destruction."
        },
        {
          "q": "DECL/X3 category",
          "a": "Impairs development/use of technology within a US weapons system."
        },
        {
          "q": "DECL/X4 category",
          "a": "US military plans or national security emergency preparedness plans."
        },
        {
          "q": "DECL/X5 category",
          "a": "Foreign government information."
        },
        {
          "q": "DECL/X6 category",
          "a": "Damages foreign relations/reveals confidential source/undermines ongoing diplomacy."
        },
        {
          "q": "DECL/X7 category",
          "a": "Impairs protection of President/VP/others protected for national security."
        },
        {
          "q": "DECL/X8 category",
          "a": "Violates statute, treaty, or international agreement."
        },
        {
          "q": "GENSER Format Line 13 name",
          "a": "Break (between text and footer)."
        },
        {
          "q": "Format Line 13 prosign",
          "a": "BT."
        },
        {
          "q": "Format Line 13 purpose",
          "a": "Break between body text and footer."
        },
        {
          "q": "GENSER Format Line 14 name",
          "a": "Validation."
        },
        {
          "q": "Format Line 14 example",
          "a": "#0001."
        },
        {
          "q": "Validation duplicates what?",
          "a": "SSN from Format Line 2."
        },
        {
          "q": "Purpose of validation",
          "a": "Verifies message complete and not a straggler."
        },
        {
          "q": "Define \u201cstraggler\u201d (as stated)",
          "a": "Combination of two different messages where beginning of one is combined with end of another."
        },
        {
          "q": "GENSER Format Line 16 name",
          "a": "Ending Sign (End of Message)."
        },
        {
          "q": "End of message marker",
          "a": "NNNN."
        },
        {
          "q": "End of message structure",
          "a": "8 carriage returns/line feeds then NNNN."
        },
        {
          "q": "Why 8 blank lines?",
          "a": "Provide physical separation between messages."
        },
        {
          "q": "Why \u201cNNNN\u201d?",
          "a": "Unique characters recognized by systems as end of a message."
        },
        {
          "q": "To identify Format Line 1, look for what?",
          "a": "VZCZC + 3-letter station/channel + 3-digit sequence."
        },
        {
          "q": "To identify Format Line 2, what does it begin with?",
          "a": "A precedence letter (R/P/O/Z) followed by header groups."
        },
        {
          "q": "To identify Format Line 4, what does it start with?",
          "a": "3-letter OPSIG (e.g., ZNR or ZNY)."
        },
        {
          "q": "To identify Format Line 5, what starts the DTG line?",
          "a": "Precedence letter + space then DDHHMMZ MMM YY."
        },
        {
          "q": "To identify originator line, what keyword is used?",
          "a": "FM."
        },
        {
          "q": "To identify action addressee line, what keyword is used?",
          "a": "TO."
        },
        {
          "q": "To identify info addressee line, what keyword is used?",
          "a": "INFO."
        },
        {
          "q": "Header-to-body break prosign",
          "a": "BT (Format Line 11)."
        },
        {
          "q": "Body-to-footer break prosign",
          "a": "BT (Format Line 13)."
        },
        {
          "q": "How to confirm message completeness quickly",
          "a": "Check Validation (# + SSN) matches SSN in header and message ends with NNNN."
        },
        {
          "q": "GENSER vs DSSCS (key distinction)",
          "a": "GENSER is common DoD format; DSSCS is special purpose worldwide system for record traffic that can contain SI/SCI."
        },
        {
          "q": "CRITIC vs routine messaging (key distinction)",
          "a": "CRITIC reports critical info to senior decision makers; highest priority; fastest paths; modified SI format."
        },
        {
          "q": "AIG vs CAD (difference)",
          "a": "AIG is 16+ PLAs grouped; CAD is 4+ PLAs with common chain of command."
        },
        {
          "q": "Action addressee vs INFO addressee",
          "a": "Action must act; INFO is informed only."
        },
        {
          "q": "Originator vs drafter vs releaser",
          "a": "Originator is sending authority; drafter composes; releaser authorizes transmission."
        },
        {
          "q": "Where does message go after release?",
          "a": "Telecommunications/message center for transmission."
        },
        {
          "q": "Z in DTG stands for",
          "a": "Zulu (GMT)."
        },
        {
          "q": "Julian date is what?",
          "a": "Day-of-year number 001\u2013365 (366 leap year)."
        },
        {
          "q": "What does \u201cU\u201d in header classification position mean?",
          "a": "Unclassified."
        },
        {
          "q": "What does \u201cT\u201d in header classification position mean?",
          "a": "Top Secret."
        },
        {
          "q": "Purpose of classification redundancy",
          "a": "Repeats classification to reduce error/mismatch."
        }
      ]
